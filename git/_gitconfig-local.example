# 本地 git 覆盖配置 - 不提交 git
# 复制此文件到 ~/.gitconfig-local
#
# [user] 身份已移到 ~/.gitconfig 主文件，确保 sandboxed 工具也能读到
# 此处仅放本地覆盖配置

# 按仓库地址区分用户身份（可选）
# 匹配公司 GitLab 的 HTTP/HTTPS 仓库
#[includeIf "hasconfig:remote.*.url:http*://YOUR_COMPANY_GIT_URL/**"]
#    path = ~/.gitconfig-company
# 匹配公司 GitLab 的 SSH 仓库
#[includeIf "hasconfig:remote.*.url:git@YOUR_COMPANY_GIT_URL:**/**"]
#    path = ~/.gitconfig-company

# GitHub 代理（可选）
#[url "https://gh-proxy.org/https://github.com/"]
#	insteadof = https://github.com/
