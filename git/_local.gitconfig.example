# 本地 git 配置 - 不提交 git
# 复制此文件到 ~/.local.gitconfig

# 用户身份（默认）
[user]
	name = YOUR_NAME
	email = YOUR_EMAIL

# 按仓库地址区分用户身份（可选）
# 例如公司 GitLab 用公司邮箱，其他用个人邮箱
#[includeIf "hasconfig:remote.*.url:**gitlab.chinastock.com.cn/**"]
#	[user]
#		name = COMPANY_NAME
#		email = COMPANY_EMAIL

# git hooks 路径（可选）
#[core]
#	hooksPath = ~/workspace/git-hooks/hooks

# GitLab 认证（可选）
#[url "http://oauth2:YOUR_TOKEN@gitlab.chinastock.com.cn"]
#	insteadof = http://gitlab.chinastock.com.cn

# GitHub 代理（可选）
#[url "https://gh-proxy.org/https://github.com/"]
#	insteadof = https://github.com/

# Homebrew Taps - 避免全局 hook 导致 git-lfs hook 不生效（可选）
#[includeIf "gitdir:/opt/homebrew/Library/Taps/"]
#	path = ~/.gitconfig-homebrew-taps
#[includeIf "gitdir:/usr/local/Homebrew/Library/Taps/"]
#	path = ~/.gitconfig-homebrew-taps
