# pyenv-install-fast
pyenv-install-fast() {
  local version=$1
  if [[ -z "$version" ]]; then
    echo "Usage: pyenv-install-fast <version>"
    return 1
  fi
  local url="https://repo.huaweicloud.com/python/$version/Python-$version.tar.xz"
  echo "Downloading from: $url"
  wget "$url" -P ~/.pyenv/cache/ || { echo "Download failed!"; return 1; }
  pyenv install "$version"
}

