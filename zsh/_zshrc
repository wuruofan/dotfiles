alias datetime='date +%Y-%m-%d\ %H:%M:%S'
alias timestamp='date +%s'

# Android NDK/SDK
export NDKROOT=$HOME/Library/Android/sdk/ndk/23.1.7779620
export ANDROID_NDK=${NDKROOT}
export ANDROID_SDK=$HOME/Library/Android/sdk
