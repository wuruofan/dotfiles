[ -f "$CLAUDE_CONF_DIR/claude-code.shrc" ] && source "$CLAUDE_CONF_DIR/claude-code.shrc"

# tmux 配置
source "$DOTFILES_DIR/tmux/tmux.shrc"

# OpenClaw Completion
